# ==============================
# MeatHub Frontend (Next.js) — .gitignore
# ==============================

# ── 의존성 ───────────────────────────────────────────────
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# ── Next.js 빌드 ────────────────────────────────────────
/.next/
/out/
/build
/dist

# ── 테스트 ───────────────────────────────────────────────
/coverage

# ── 환경변수 / 시크릿 ───────────────────────────────────
.env
.env*.local
.env.development.local
.env.test.local
.env.production.local
!.env.example
secrets.json
credentials.json

# ── TypeScript ───────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── 캐시 ─────────────────────────────────────────────────
.cache/
.eslintcache
.stylelintcache

# ── IDE / 에디터 ─────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS 파일 ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── 로그 ─────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── 임시 / 백업 ─────────────────────────────────────────
*.tmp
*.temp
*.bak
*.backup

# ── Vercel ───────────────────────────────────────────────
.vercel

# ── 기타 ─────────────────────────────────────────────────
*.pem
icon_data/
storybook-static/
