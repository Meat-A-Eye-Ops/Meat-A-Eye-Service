# ============================================================
# Meat-A-Eye Frontend - Environment Variables Example
# ============================================================
# 이 파일을 복사하여 .env.local 파일을 생성하고 실제 값으로 채워주세요.
# cp .env.example .env.local

# ==============================
# 🚀 Application Settings
# ==============================
NEXT_PUBLIC_APP_NAME=Meat-A-Eye
NEXT_PUBLIC_APP_VERSION=1.0.0

# ==============================
# 🔌 Backend API URL
# ==============================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ==============================
# 🔑 API Keys (Frontend에서 사용하지 않음)
# ==============================
# 주의: 프론트엔드에서는 API 키를 직접 사용하지 않습니다.
# 모든 API 호출은 백엔드를 통해 이루어집니다.

# ==============================
# 🎨 Feature Flags (Optional)
# ==============================
# NEXT_PUBLIC_ENABLE_GUEST_MODE=true
# NEXT_PUBLIC_ENABLE_AI_ANALYSIS=true
# NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true

# ==============================
# 📝 Notes
# ==============================
# 1. NEXT_PUBLIC_ 접두사:
#    - 브라우저에서 접근 가능한 환경 변수
#    - 민감한 정보는 절대 NEXT_PUBLIC_으로 시작하지 마세요!
#
# 2. API_BASE_URL:
#    - 개발: http://localhost:8000
#    - 프로덕션: https://your-backend-domain.com
#
# 3. 환경별 파일:
#    - .env.local (로컬 개발)
#    - .env.development (개발 환경)
#    - .env.production (프로덕션 환경)
